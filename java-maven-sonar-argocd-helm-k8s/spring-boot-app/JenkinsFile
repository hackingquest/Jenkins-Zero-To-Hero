pipeline {
   agent {
        docker {
          image 'maven:3.9.6-eclipse-temurin-17'
          args '--user root -v /var/run/docker.sock:/var/run/docker.sock' // mount Docker socket to access the host's Docker daemon
        }
      }
  environment {
        // Pointing to paths INSIDE the container, NOT the EC2 host
        JAVA_HOME = '/opt/java/openjdk'
        MAVEN_HOME = '/usr/share/maven' 
        PATH = "${JAVA_HOME}/bin:${MAVEN_HOME}/bin:${env.PATH}"
    }
  
  stages {
    stage('Checkout') {
       
      steps {
        sh 'echo passed'
        //git branch: 'main', url: 'https://github.com/hackingquest/Jenkins-Zero-To-Hero.git'
      }
    }
    
    stage('Build and Test') {
            
      steps {
        sh 'ls -ltr'
        // build the project and create a JAR file
        sh 'cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && mvn clean package'
      }
    }
    stage('Static Code Analysis') {
          
      environment {
        SONAR_URL = "http://3.25.113.187:9000"
      }
      steps {
        withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
          sh 'cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && mvn sonar:sonar -Dsonar.login=$SONAR_AUTH_TOKEN -Dsonar.host.url=${SONAR_URL}'
        }
      }
    }
    stage('Build and Push Docker Image') {
      
      environment {
        DOCKER_IMAGE = "hackerpro25/ultimate-cicd:${BUILD_NUMBER}"
        // DOCKERFILE_LOCATION = "java-maven-sonar-argocd-helm-k8s/spring-boot-app/Dockerfile"
        REGISTRY_CREDENTIALS = credentials('docker-cred')
      }
      steps {
        script {
            // PASTE THE DEBUG SCRIPT HERE
            sh '''
                echo "Current User: $(whoami)"
                echo "Current Environment Path: $PATH"
                ls -l /usr/bin/docker || echo "Docker NOT in /usr/bin"
                cat /etc/os-release | grep PRETTY_NAME
            '''
            // ADD THESE TWO LINES TO INSTALL THE CLI ON THE FLY
            sh 'apt-get update && apt-get install -y docker.io'
            sh 'cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && /usr/bin/docker build -t ${DOCKER_IMAGE} .'
            def dockerImage = docker.image("${DOCKER_IMAGE}")
            docker.withRegistry('https://index.docker.io/v1/', "docker-cred") {
                dockerImage.push()
            }
        }
      }
    }
    stage('Update Deployment File') {
        
        environment {
            GIT_REPO_NAME = "Jenkins-Zero-To-Hero"
            GIT_USER_NAME = "hackingquest"
        }
        steps {
            withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
                sh '''
                  # Basic Git Setup
                  git config --global user.email "veda51sri@gmail.com"
                  git config --global user.name "hackingquest"
                  git config --global --add safe.directory /var/lib/jenkins/workspace/first_pipeline
                  
                  # Ensure we are on the branch
                  git checkout main || git checkout -b main
                  git pull https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} main --rebase
                  # Update the image line regardless of what the old image name was
                  sed -i "s|image: .*|image: hackerpro25/ultimate-cicd:${BUILD_NUMBER}|g" java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml
      
                  # Stage and Commit
                  git add java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml
                  
                  if ! git diff-index --quiet HEAD; then
                    git commit -m "Update deployment image to version ${BUILD_NUMBER}"
                    
                    # Push using the token for authentication
                    git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
                  else
                    echo "No changes detected in deployment.yml, skipping commit."
                  fi  
                '''
            }
        }
    }
  }
}
